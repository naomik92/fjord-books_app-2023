<div>
  <p>
    <strong><%= User.human_attribute_name(:postcode) %>:</strong>
    <%= @user.postcode %>
  </p>

  <p>
    <strong><%= User.human_attribute_name(:address) %>:</strong>
    <%= @user.address %>
  </p>

  <p>
    <strong><%= User.human_attribute_name(:self_introduction) %>:</strong>
